---
interface Props {
  lang: 'ja' | 'en';
}

const { lang } = Astro.props;
const isEn = lang === 'en';
const base = isEn ? '/en' : '';
---

<footer class="footer">
  <div class="footer-inner">
    <div>
      <a href={`${base}/`} class="footer-logo">
        <span class="logo-mark"><img src="/icon.png" alt="" width="28" height="28" /></span>
        CyberTrip
      </a>
      <div class="footer-company-info">
        {isEn ? 'CyberTrip, Inc.' : '株式会社CyberTrip'}
      </div>
    </div>
    <div class="footer-links">
      <div class="footer-links-col">
        <a href={`${base}/philosophy/`}>Philosophy</a>
        <a href={`${base}/drift/`}>Drift</a>
        <a href={`${base}/company/`}>Company</a>
        <a href={`${base}/news/`}>News</a>
      </div>
      <div class="footer-links-col">
        <a href="mailto:cybertrip.inc@gmail.com">{isEn ? 'Contact' : 'お問い合わせ'}</a>
        <a href={`${base}/privacy/`}>{isEn ? 'Privacy Policy' : 'プライバシーポリシー'}</a>
        <a href={`${base}/terms/`}>{isEn ? 'Terms of Service' : '利用規約'}</a>
        <a href={`${base}/child-safety/`}>{isEn ? 'Child Safety' : '児童安全基準'}</a>
        <a href={`${base}/external-transmission/`}>{isEn ? 'External Transmission Policy' : '外部送信ポリシー'}</a>
        <a href={`${base}/notice/`}>{isEn ? 'Public Notice' : '公告'}</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span class="footer-copy">&copy; 2026 CyberTrip, Inc. All rights reserved.</span>
    <div class="footer-bottom-right">
      <div class="footer-lang">
        <a href="/" class:list={[{ active: !isEn }]}>JP</a>
        <a href="/en/" class:list={[{ active: isEn }]}>EN</a>
      </div>
    </div>
  </div>
</footer>
